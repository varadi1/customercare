# =============================================================================
# CustomerCare — Environment Variables
# =============================================================================
# Copy to .env and fill in the values:
#   cp .env.example .env
#
# Required keys are marked with [REQUIRED]
# Optional keys have sensible defaults
# =============================================================================

# --- LLM Providers -----------------------------------------------------------
# At least one is [REQUIRED] for draft generation
OPENAI_API_KEY=                         # [REQUIRED] GPT-5.4 fallback + KG extraction (gpt-4o-mini)
ANTHROPIC_API_KEY=                      # [REQUIRED] Opus 4.6 — primary LLM
GOOGLE_API_KEY=                         # Gemini — tertiary fallback
COHERE_API_KEY=                         # Cohere reranker fallback (if local reranker down)

# --- Email (MS Graph API) ----------------------------------------------------
# [REQUIRED] for email processing pipeline
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_USER_EMAIL=                       # Authenticated mailbox for draft creation
SHARED_MAILBOXES=lakossagitarolo@neuzrt.hu  # Comma-separated monitored mailboxes

# --- Program-specific DB (optional) -------------------------------------------
# External database for applicant status lookups
# Supports MySQL (pymysql) or Azure SQL (pymssql) — see radix_client.py
PROGRAM_DB_DRIVER=mysql                 # "mysql" (pymysql) or "mssql" (pymssql/Azure SQL)
PROGRAM_DB_HOST=
PROGRAM_DB_PORT=3306
PROGRAM_DB_USER=
PROGRAM_DB_PASSWORD=
PROGRAM_DB_NAME=
PROGRAM_DB_ENABLED=false                # Set true after credentials configured

# --- Discord Notifications ---------------------------------------------------
# Optional — monitoring alerts
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# --- Langfuse Observability ---------------------------------------------------
# Optional — auto-configured if running langfuse from docker-compose
LANGFUSE_HOST=http://cc-langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Autonomous Processing ----------------------------------------------------
AUTO_PROCESS_ENABLED=false              # Set true to enable email polling + draft generation

# --- Report Output ------------------------------------------------------------
# Obsidian vault path for reports, or any writable directory
# REPORT_DIR=~/Library/Mobile Documents/iCloud~md~obsidian/Documents/Para/!inbox/!reports

# --- Embedding / Reranker (native GPU services) -------------------------------
# These run natively (not in Docker) — install.sh sets them up
# Defaults work if services are on the same machine
# BGE_M3_URL=http://host.docker.internal:8104        # search instance
# BGE_M3_INGEST_URL=http://host.docker.internal:8114  # ingest instance
# EMBEDDING_DIMENSIONS=1024

# --- Learning System Flags ----------------------------------------------------
FEEDBACK_ANALYTICS_ENABLED=true         # Level 1: draft-vs-sent comparison
DSPY_ENABLED=false                      # Level 3: DSPy prompt optimization
# RERANKER_MODEL_PATH=                  # Level 5: fine-tuned reranker path (reranker service env)
